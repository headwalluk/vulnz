{
  "name": "vulnz",
  "version": "1.30.0",
  "description": "Vulnerability database for WordPress plugins and themes",
  "main": "src/index.js",
  "bin": {
    "vulnz": "./bin/vulnz.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "nodemon src/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "NODE_ENV=production node src/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/headwalluk/vulnz.git"
  },
  "keywords": [
    "wordpress",
    "vulnerability",
    "security",
    "plugin",
    "theme",
    "scanner",
    "cve",
    "database",
    "wordfence",
    "api"
  ],
  "author": "Paul Faulkner",
  "license": "MIT",
  "type": "commonjs",
  "overrides": {
    "validator": "13.15.23",
    "glob": "^10.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "mariadb": "^3.4.5",
    "maxmind": "^5.0.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-headerapikey": "^1.2.2",
    "sanitize-html": "^2.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prettier-plugin-sh": "^0.18.0",
    "sqlite3": "^6.0.1",
    "supertest": "^7.1.4"
  }
}
